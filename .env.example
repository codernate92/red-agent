# red-agent — API key environment variables
#
# Copy this file to `.env` and fill in the keys you want to use. The CLI
# auto-loads `.env` via python-dotenv at startup; any variable already set
# in your shell environment wins (override=False).
#
# NEVER commit .env — it's in .gitignore.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=

# Optional overrides for self-hosted endpoints
# VLLM_BASE_URL=http://localhost:8000/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1
